# ============================================================
# Blood Banking System — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it's in .gitignore).
# ============================================================

# MySQL
DB_URL=jdbc:mysql://localhost:3306/blood_banking_system?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# JPA — use "update" for dev, "validate" for production
DDL_AUTO=update

# JWT — use a long, random string in production (min 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRATION=86400000

# Cookie security — set to true in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
